---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Photography and projects by Cian Brassil.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — brassil.net</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@1,9..144,400&family=IBM+Plex+Mono:ital,wght@0,400;0,500;1,400&display=swap"
    />

    <ClientRouter />
  </head>
  <body class="bg-background text-ink font-mono min-h-screen flex flex-col">

    <header id="site-header">
      <nav>
        <a href="/" class="wordmark">
          <span class="wordmark-dot" aria-hidden="true"></span>
          brassil.net
        </a>
        <ul>
          <li><a href="/photos">Photos</a></li>
          <li><a href="/apps">Apps</a></li>
          <li><a href="/cv">CV</a></li>
        </ul>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <span>&copy; {new Date().getFullYear()} brassil.net</span>
        <ul>
          <li><a href="/photos">Photos</a></li>
          <li><a href="/apps">Apps</a></li>
          <li><a href="/cv">CV</a></li>
        </ul>
      </div>
    </footer>

  </body>
</html>

<script>
  document.addEventListener('astro:page-load', () => {
    const header = document.getElementById('site-header');
    if (!header) return;
    const update = () => header.classList.toggle('scrolled', window.scrollY > 0);
    window.addEventListener('scroll', update, { passive: true });
    update();
  });
</script>

<style>
  #site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  :global(#site-header.scrolled) {
    background: #FFFFFF;
    border-bottom-color: #E5E5E4;
  }

  nav {
    max-width: 1280px;
    margin: 0 auto;
    padding: 14px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 13px;
    font-weight: 400;
    color: #0A0A0A;
    text-decoration: none;
    letter-spacing: 0;
  }

  .wordmark-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: #0A0A0A;
    flex-shrink: 0;
  }

  nav ul {
    display: flex;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  nav ul a {
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 12px;
    font-weight: 400;
    color: #737373;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  nav ul a:hover {
    color: #0A0A0A;
  }

  footer {
    border-top: 1px solid #E5E5E4;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 26px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-inner span,
  .footer-inner ul a {
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    color: #737373;
    text-decoration: none;
  }

  .footer-inner ul {
    display: flex;
    gap: 24px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-inner ul a:hover {
    color: #0A0A0A;
  }

  @media (max-width: 639px) {
    nav {
      padding: 12px 20px;
    }

    nav ul {
      gap: 20px;
    }

    .footer-inner {
      padding: 20px;
    }

    .footer-inner ul {
      gap: 16px;
    }
  }
</style>
