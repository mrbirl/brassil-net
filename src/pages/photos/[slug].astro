---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const photos = await getCollection('photos', ({ data }) => data.available);
  return photos.map((photo) => ({
    params: { slug: photo.data.slug },
    props: { photo },
  }));
};

const { photo } = Astro.props;
const { data } = photo;

const dateFormatted = data.dateTaken
  ? data.dateTaken.toLocaleDateString('en-IE', { month: 'long', year: 'numeric' })
  : null;
---

<BaseLayout title={data.title} description={data.description}>
  <div class="detail-page">

    <!-- Hero photo -->
    <div class="hero-wrap">
      {data.image ? (
        <Image
          src={data.image}
          alt={data.description}
          width={data.image.width}
          height={data.image.height}
          class="hero-img"
          loading="eager"
          transition:name={`photo-${data.slug}`}
        />
      ) : data.imageUrl ? (
        /* TODO: replace <img> with <Image> when local file replaces imageUrl */
        <img
          src={data.imageUrl}
          alt={data.description}
          width={data.imageWidth}
          height={data.imageHeight}
          class="hero-img"
          loading="eager"
          transition:name={`photo-${data.slug}`}
        />
      ) : null}

      {data.showCoordinates && data.location && (
        <span class="hero-coordinates">{data.location}</span>
      )}
    </div>

    <!-- Title and metadata -->
    <div class="detail-meta">
      <h1 class="detail-title">{data.title}</h1>
      {(data.location || dateFormatted) && (
        <p class="detail-info">
          {[data.location, dateFormatted].filter(Boolean).join(' · ')}
        </p>
      )}
    </div>

    {/* TODO: long description */}
    {/* TODO: print options panel */}
    {/* TODO: request-print form */}
    {/* TODO: related photos */}

  </div>
</BaseLayout>

<style>
  .detail-page {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 40px 96px;
  }

  .hero-wrap {
    position: relative;
    width: 100%;
    max-height: 75vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0A0A0A;
  }

  .hero-img {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 75vh;
    object-fit: contain;
  }

  .hero-coordinates {
    position: absolute;
    left: 20px;
    bottom: 16px;
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.04em;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5);
    pointer-events: none;
  }

  .detail-meta {
    padding-top: 32px;
  }

  .detail-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(28px, 3vw, 42px);
    font-weight: 400;
    font-style: italic;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #FF5C1F;
    margin: 0 0 12px;
  }

  .detail-info {
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 12px;
    color: #737373;
    letter-spacing: 0.04em;
    margin: 0;
  }

  @media (max-width: 767px) {
    .detail-page {
      padding: 0 20px 64px;
    }

    .hero-wrap {
      max-height: 60vh;
    }

    .hero-img {
      max-height: 60vh;
    }

    .detail-meta {
      padding-top: 24px;
    }
  }
</style>
