---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import type { ImageMetadata } from 'astro';

const allPhotos = await getCollection('photos', ({ data }) => data.available);

const photos = allPhotos.sort((a, b) => {
  const aOrder = a.data.order;
  const bOrder = b.data.order;
  if (aOrder != null && bOrder != null) return aOrder - bOrder;
  if (aOrder != null) return -1;
  if (bOrder != null) return 1;
  const aDate = a.data.dateTaken?.getTime() ?? 0;
  const bDate = b.data.dateTaken?.getTime() ?? 0;
  if (aDate !== bDate) return bDate - aDate;
  return a.id.localeCompare(b.id);
});

const years = photos
  .map(p => p.data.dateTaken?.getFullYear())
  .filter((y): y is number => y != null);
const yearRange =
  years.length === 0
    ? String(new Date().getFullYear())
    : years.length === 1
      ? String(years[0])
      : `${Math.min(...years)}–${Math.max(...years)}`;

type Orientation = 'landscape' | 'portrait' | 'square';

function getOrientation(img: ImageMetadata | undefined, w?: number, h?: number): Orientation {
  const width = img?.width ?? w ?? 0;
  const height = img?.height ?? h ?? 0;
  if (!width || !height) return 'landscape';
  const ratio = width / height;
  if (ratio >= 1.2) return 'landscape';
  if (ratio <= 0.8) return 'portrait';
  return 'square';
}

function getColSpan(gridSize: 'feature' | 'standard', orientation: Orientation): number {
  if (gridSize === 'feature') {
    if (orientation === 'landscape') return 12;
    if (orientation === 'portrait') return 7;
    return 9;
  }
  if (orientation === 'landscape') return 5;
  return 4;
}

function getAspectRatio(
  gridSize: 'feature' | 'standard',
  orientation: Orientation,
  img: ImageMetadata | undefined,
  w?: number,
  h?: number
): string {
  const natW = img?.width ?? w;
  const natH = img?.height ?? h;
  if (natW && natH) return `${natW} / ${natH}`;
  if (gridSize === 'feature') {
    if (orientation === 'landscape') return '16 / 7';
    if (orientation === 'portrait') return '3 / 4';
    return '1 / 1';
  }
  if (orientation === 'landscape') return '4 / 3';
  if (orientation === 'portrait') return '2 / 3';
  return '1 / 1';
}
---

<BaseLayout title="Photographs" description="Photography by Cian Brassil — landscapes and coastline across Ireland.">
  <div class="gallery-page">

    <div class="gallery-header">
      <h1>Photographs</h1>
      <span class="gallery-meta">{photos.length} photographs · {yearRange}</span>
    </div>

    {photos.length === 0 ? (
      <p class="empty-state">No photographs yet.</p>
    ) : (
      <div class="gallery-grid">
        {photos.map((entry) => {
          const orientation = getOrientation(
            entry.data.image,
            entry.data.imageWidth,
            entry.data.imageHeight
          );
          const colSpan = getColSpan(entry.data.gridSize, orientation);
          const aspectRatio = getAspectRatio(
            entry.data.gridSize,
            orientation,
            entry.data.image,
            entry.data.imageWidth,
            entry.data.imageHeight
          );

          return (
            <a
              href={`/photos/${entry.data.slug}`}
              class="photo-card"
              style={`grid-column: span ${colSpan};`}
              aria-label={entry.data.title}
            >
              <div class="card-inner" style={`aspect-ratio: ${aspectRatio};`}>
                {entry.data.image ? (
                  <Image
                    src={entry.data.image}
                    alt={entry.data.description}
                    width={entry.data.image.width}
                    height={entry.data.image.height}
                    class="card-img"
                    loading="lazy"
                    transition:name={`photo-${entry.data.slug}`}
                  />
                ) : entry.data.imageUrl ? (
                  /* TODO: replace <img> with <Image> when local file replaces imageUrl */
                  <img
                    src={entry.data.imageUrl}
                    alt={entry.data.description}
                    width={entry.data.imageWidth}
                    height={entry.data.imageHeight}
                    loading="lazy"
                    class="card-img"
                    transition:name={`photo-${entry.data.slug}`}
                  />
                ) : null}
                <span class="card-title">{entry.data.title}</span>
              </div>
            </a>
          );
        })}
      </div>
    )}

  </div>
</BaseLayout>

<style>
  .gallery-page {
    max-width: 1280px;
    margin: 0 auto;
    padding: 56px 40px 96px;
  }

  .gallery-header {
    display: flex;
    align-items: baseline;
    gap: 24px;
    margin-bottom: 64px;
  }

  .gallery-header h1 {
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #0A0A0A;
    margin: 0;
  }

  .gallery-meta {
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    font-weight: 400;
    color: #737373;
    letter-spacing: 0.04em;
  }

  .empty-state {
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 13px;
    color: #737373;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: 60px;
    row-gap: 100px;
    grid-auto-flow: dense;
    align-items: start;
  }

  .photo-card {
    display: block;
    text-decoration: none;
    cursor: pointer;
  }

  .card-inner {
    position: relative;
    overflow: hidden;
  }

  .card-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: filter 0.2s ease;
  }

  .photo-card:hover .card-img {
    filter: brightness(1.08);
  }

  .card-title {
    position: absolute;
    left: 18px;
    bottom: 14px;
    color: #FF5C1F;
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    letter-spacing: 0.01em;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.6);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    pointer-events: none;
    white-space: nowrap;
  }

  .photo-card:hover .card-title {
    opacity: 1;
    transform: translateY(0);
  }

  /* Touch/coarse pointer: title always visible */
  @media (pointer: coarse) {
    .card-title {
      opacity: 0.78;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .card-img {
      transition: none;
    }
    .card-title {
      transition: none;
    }
  }

  /* Mobile: single column, full-width */
  @media (max-width: 767px) {
    .gallery-page {
      padding: 40px 20px 64px;
    }

    .gallery-header {
      margin-bottom: 40px;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
      column-gap: 0;
      row-gap: 32px;
    }

    .photo-card {
      grid-column: 1 / -1 !important;
    }

    .card-title {
      opacity: 0.78;
      transform: none;
    }
  }
</style>
