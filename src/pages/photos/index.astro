---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const allPhotos = await getCollection('photos', ({ data }) => data.available);

const photos = allPhotos.sort((a, b) => {
  const aOrder = a.data.order;
  const bOrder = b.data.order;
  if (aOrder != null && bOrder != null) return aOrder - bOrder;
  if (aOrder != null) return -1;
  if (bOrder != null) return 1;
  const aDate = a.data.dateTaken?.getTime() ?? 0;
  const bDate = b.data.dateTaken?.getTime() ?? 0;
  if (aDate !== bDate) return bDate - aDate;
  return a.id.localeCompare(b.id);
});

const years = photos
  .map(p => p.data.dateTaken?.getFullYear())
  .filter((y): y is number => y != null);
const yearRange =
  years.length === 0
    ? String(new Date().getFullYear())
    : years.length === 1
      ? String(years[0])
      : `${Math.min(...years)}–${Math.max(...years)}`;

// Justified layout constants — computed at 1200px effective content width.
// TARGET_HEIGHT=320 so two 3:2 landscape photos (480px each) fit per row
// (480+24+480=984<1200); justified row heights end up ~392px in practice.
const EFFECTIVE_WIDTH = 1200;
const TARGET_HEIGHT = 320;
const GAP = 24;

type PhotoEntry = CollectionEntry<'photos'>;

type FeatureRow = {
  type: 'feature';
  entry: PhotoEntry;
  ar: number;
};

type StandardRow = {
  type: 'standard';
  items: Array<{ entry: PhotoEntry; ar: number; width: number; height: number }>;
  isLast: boolean;
};

type Row = FeatureRow | StandardRow;

function getAspectRatio(entry: PhotoEntry): number {
  const w = entry.data.image?.width ?? entry.data.imageWidth ?? 0;
  const h = entry.data.image?.height ?? entry.data.imageHeight ?? 0;
  if (!w || !h) return 4 / 3;
  return w / h;
}

function buildRows(entries: PhotoEntry[]): Row[] {
  const rows: Row[] = [];
  let pending: Array<{ entry: PhotoEntry; ar: number }> = [];

  function flushPending(isLast: boolean) {
    if (pending.length === 0) return;
    const totalGaps = (pending.length - 1) * GAP;
    const available = EFFECTIVE_WIDTH - totalGaps;
    const sumAr = pending.reduce((s, p) => s + p.ar, 0);
    // Single-photo rows stay at natural size — stretching to full width would
    // make them visually indistinguishable from feature rows.
    const useNaturalSize = isLast || pending.length === 1;
    const height = useNaturalSize ? TARGET_HEIGHT : available / sumAr;
    rows.push({
      type: 'standard',
      items: pending.map(({ entry, ar }) => ({
        entry,
        ar,
        width: Math.round(height * ar),
        height: Math.round(height),
      })),
      isLast,
    });
    pending = [];
  }

  for (const entry of entries) {
    const ar = getAspectRatio(entry);

    if (entry.data.gridSize === 'feature') {
      flushPending(false);
      rows.push({ type: 'feature', entry, ar });
      continue;
    }

    if (pending.length > 0) {
      const currentNaturalWidth =
        pending.reduce((s, p) => s + TARGET_HEIGHT * p.ar, 0) +
        (pending.length - 1) * GAP;
      if (currentNaturalWidth + GAP + TARGET_HEIGHT * ar > EFFECTIVE_WIDTH) {
        flushPending(false);
      }
    }

    pending.push({ entry, ar });
  }

  flushPending(true);
  return rows;
}

const rows = buildRows(photos);
---

<BaseLayout title="Photographs" description="Photography by Cian Brassil — landscapes and coastline across Ireland.">
  <div class="gallery-page">

    <div class="gallery-header">
      <h1>Photographs</h1>
      <span class="gallery-meta">{photos.length} photographs · {yearRange}</span>
    </div>

    {photos.length === 0 ? (
      <p class="empty-state">No photographs yet.</p>
    ) : (
      <div class="gallery-rows">
        {rows.map((row) => {
          if (row.type === 'feature') {
            const { entry, ar } = row;
            return (
              <div class="gallery-row gallery-row--feature">
                <a
                  href={`/photos/${entry.data.slug}`}
                  class="photo-card"
                  aria-label={entry.data.title}
                >
                  <div class="card-inner" style={`aspect-ratio: ${ar};`}>
                    {entry.data.image ? (
                      <Image
                        src={entry.data.image}
                        alt={entry.data.description}
                        width={entry.data.image.width}
                        height={entry.data.image.height}
                        class="card-img"
                        loading="lazy"
                        transition:name={`photo-${entry.data.slug}`}
                      />
                    ) : entry.data.imageUrl ? (
                      <img
                        src={entry.data.imageUrl}
                        alt={entry.data.description}
                        width={entry.data.imageWidth}
                        height={entry.data.imageHeight}
                        loading="lazy"
                        class="card-img"
                        transition:name={`photo-${entry.data.slug}`}
                      />
                    ) : null}
                    <span class="card-title">{entry.data.title}</span>
                  </div>
                </a>
              </div>
            );
          }

          // standard justified row
          return (
            <div class="gallery-row gallery-row--standard">
              {row.items.map(({ entry, ar, width, height }) => (
                <a
                  href={`/photos/${entry.data.slug}`}
                  class="photo-card"
                  style={`width: ${width}px;`}
                  aria-label={entry.data.title}
                >
                  <div class="card-inner" style={`height: ${height}px; aspect-ratio: ${ar};`}>
                    {entry.data.image ? (
                      <Image
                        src={entry.data.image}
                        alt={entry.data.description}
                        width={entry.data.image.width}
                        height={entry.data.image.height}
                        class="card-img"
                        loading="lazy"
                        transition:name={`photo-${entry.data.slug}`}
                      />
                    ) : entry.data.imageUrl ? (
                      <img
                        src={entry.data.imageUrl}
                        alt={entry.data.description}
                        width={entry.data.imageWidth}
                        height={entry.data.imageHeight}
                        loading="lazy"
                        class="card-img"
                        transition:name={`photo-${entry.data.slug}`}
                      />
                    ) : null}
                    <span class="card-title">{entry.data.title}</span>
                  </div>
                </a>
              ))}
            </div>
          );
        })}
      </div>
    )}

  </div>
</BaseLayout>

<style>
  .gallery-page {
    max-width: 1280px;
    margin: 0 auto;
    padding: 56px 40px 96px;
  }

  .gallery-header {
    display: flex;
    align-items: baseline;
    gap: 24px;
    margin-bottom: 64px;
  }

  .gallery-header h1 {
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #0A0A0A;
    margin: 0;
  }

  .gallery-meta {
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    font-weight: 400;
    color: #737373;
    letter-spacing: 0.04em;
  }

  .empty-state {
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 13px;
    color: #737373;
  }

  /* Row container */
  .gallery-rows {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .gallery-row {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }

  /* Feature row: single photo, full container width */
  .gallery-row--feature .photo-card {
    width: 100%;
  }

  /* Standard row: photos have explicit widths set inline */
  .gallery-row--standard .photo-card {
    flex-shrink: 0;
  }

  .photo-card {
    display: block;
    text-decoration: none;
    cursor: pointer;
  }

  .card-inner {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .card-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: filter 0.2s ease;
  }

  .photo-card:hover .card-img {
    filter: brightness(1.08);
  }

  .card-title {
    position: absolute;
    left: 18px;
    bottom: 14px;
    color: #FF5C1F;
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    letter-spacing: 0.01em;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.6);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    pointer-events: none;
    white-space: nowrap;
  }

  .photo-card:hover .card-title {
    opacity: 1;
    transform: translateY(0);
  }

  /* Touch devices: no title overlay */
  @media (pointer: coarse) {
    .card-title {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .card-img {
      transition: none;
    }
    .card-title {
      transition: none;
    }
  }

  /* Mobile: single column, full-width per photo */
  @media (max-width: 767px) {
    .gallery-page {
      padding: 40px 20px 64px;
    }

    .gallery-header {
      margin-bottom: 40px;
    }

    .gallery-rows {
      gap: 32px;
    }

    .gallery-row {
      flex-direction: column;
      gap: 32px;
    }

    /* Override all inline widths/heights — let aspect-ratio drive sizing */
    .photo-card {
      width: 100% !important;
    }

    .card-inner {
      height: auto !important;
    }

    .card-title {
      display: none;
    }
  }
</style>
